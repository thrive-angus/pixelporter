{
  "extends": "@create-figma-plugin/tsconfig",
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["DOM", "DOM.Iterable", "ES2020"],
    "types": ["@figma/plugin-typings", "node"],
    "skipLibCheck": true,
    "moduleResolution": "node",
    "strict": false,
    "ignoreDeprecations": "6.0"
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}